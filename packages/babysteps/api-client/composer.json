{
    "name": "babysteps/api-client",
    "description": "API client package for Babysteps mobile app backend communication",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Babysteps\\ApiClient\\": "src/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0",
        "nativephp/mobile": "^3.0",
        "nativephp/mobile-secure-storage": "^1.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Babysteps\\ApiClient\\ApiClientServiceProvider"
            ]
        }
    }
}
